/*
  appsettings.json — главный файл конфигурации ASP.NET Core
  Читается при старте сервера через builder.Configuration
  Значения доступны через: builder.Configuration["Ключ"]
  или builder.Configuration.GetConnectionString("DefaultConnection")

  Существуют также:
  - appsettings.Development.json — для режима разработки (перезаписывает этот файл)
  - appsettings.Production.json  — для production окружения
*/

{
  // ── Строки подключения к базе данных ──────────────────────
  // Используется в Program.cs:
  // options.UseNpgsql(builder.Configuration.GetConnectionString("DefaultConnection"))
  "ConnectionStrings": {
    // Строка подключения к PostgreSQL через провайдер Npgsql
    // Формат: Host=сервер;Database=имя_бд;Username=пользователь;Password=пароль
    // Host=localhost        — PostgreSQL запущен на том же ПК что и сервер
    // Database=PhotoViewerDb — имя базы данных (создаётся автоматически через EnsureCreated)
    // Username=postgres      — стандартный суперпользователь PostgreSQL
    // Password=postgres      — пароль (установлен при инсталляции или через ALTER USER)
    "DefaultConnection": "Host=localhost;Database=PhotoViewerDb;Username=postgres;Password=СВОЙ_ПАРОЛЬ"
  },

  // ── Настройки логирования ──────────────────────────────────
  // Контролирует какие сообщения выводятся в консоль при работе сервера
  "Logging": {
    "LogLevel": {
      // Default — уровень для всех категорий по умолчанию
      // Information: выводит информационные сообщения (старт сервера, запросы)
      // Другие уровни: Trace, Debug, Information, Warning, Error, Critical, None
      "Default": "Information",

      // Microsoft.AspNetCore — логи самого фреймворка ASP.NET Core
      // Warning: показывает только предупреждения и ошибки (меньше шума в консоли)
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // ── Разрешённые хосты ─────────────────────────────────────
  // AllowedHosts — какие хосты (Host заголовок) принимает сервер
  // "*" — принимать запросы от любого хоста (нужно для сетевого доступа)
  // В production лучше указать конкретный домен: "example.com;www.example.com"
  "AllowedHosts": "*"
}
